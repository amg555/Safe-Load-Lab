{
  "enabled": true,
  "name": "Auto Lint & Format",
  "description": "Runs ESLint and Prettier on save for TS/JS/Vue files",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.js",
      "*.vue",
      "*.tsx",
      "*.jsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint -- --fix",
    "timeout": 30
  }
}