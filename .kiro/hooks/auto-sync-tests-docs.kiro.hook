{
  "enabled": true,
  "name": "Auto Sync Tests & Docs",
  "description": "Triggers agent to update unit tests and documentation fragments when core logic files change",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/composables/*.ts",
      "src/utils/*.ts",
      "src/lib/*.ts",
      "server/utils/*.ts"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Core logic changed. Check if related unit tests or doc fragments need updates. Update only if breaking changes or new exports. Keep compact."
  }
}